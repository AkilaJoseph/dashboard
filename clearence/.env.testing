APP_NAME="MUST Clearance"
APP_ENV=testing
APP_KEY=base64:dGVzdGluZ2tleWZvcnRlc3RpbmdwdXJwb3Nlc29ubHk=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=null
LOG_LEVEL=error

# phpunit.xml overrides DB, cache, queue, session, mail — listed here
# as documentation and for artisan --env=testing commands
DB_CONNECTION=sqlite
DB_DATABASE=:memory:

BROADCAST_CONNECTION=null
CACHE_STORE=array
QUEUE_CONNECTION=sync
SESSION_DRIVER=array
MAIL_MAILER=array

BCRYPT_ROUNDS=4

FILESYSTEM_DISK=local
